# LLM 提供商（deepseek | openai | anthropic）
LLM_PROVIDER=deepseek
# 通用 API Key（优先于 DEEPSEEK_API_KEY）
LLM_API_KEY=sk-your-api-key-here
# 请求地址（OpenAI 兼容用，不填则使用 provider 默认地址）
LLM_BASE_URL=https://api.deepseek.com
# 模型名称（优先于 DEEPSEEK_MODEL）
LLM_MODEL=deepseek-chat

# 向后兼容：以下旧变量在新变量未设置时作为 fallback
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 请求超时（秒，默认 10）
REQUEST_TIMEOUT=10

# Shell 安全配置
SHELL_AUTO_CONFIRM=false         # true=自动确认所有非高风险命令
SHELL_HIGH_RISK_BLOCK=true       # true=阻止高风险命令
SHELL_ALLOWED_PATTERNS=          # 逗号分隔的自定义安全命令模式
SHELL_BLOCKED_PATTERNS=          # 逗号分隔的自定义拦截模式

# 搜索 API
TAVILY_API_KEY=tvly-xxx          # Tavily 搜索（可选，配置后搜索优先使用 Tavily）
BING_API_KEY=                    # Bing 搜索（可选，作为 Tavily/DuckDuckGo 的 fallback）

# MiaoGent 数据目录（默认 ~/.miaogent/，不填则自动创建）
MIAOGENT_HOME=

# 数据库路径（相对于项目根，默认 ~/.miaogent/history.db）
DB_PATH=data/history.db

# 会话管理
MAX_TURNS=10                     # 触发压缩的轮数上限
MAX_MESSAGE_CHARS=12000          # 触发压缩的消息字符数上限

# 压缩模型（留空使用主模型）
COMPRESSION_MODEL=
